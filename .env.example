# Research Harness Configuration
# Copy this file to .env or .envrc and fill in your values.
# cp .env.example .envrc

# === Database ===
# Path to the SQLite paper database (default: .research-harness/pool.db)
# RESEARCH_HARNESS_DB_PATH=~/.research-harness/pool.db

# === Paper Sources ===
# Semantic Scholar API key (1 req/s without key; higher limits with key)
# Get yours at: https://www.semanticscholar.org/product/api
S2_API_KEY=YOUR_S2_API_KEY_HERE

# Unpaywall email (required for unpaywall-mcp; used for open-access PDF lookup)
UNPAYWALL_EMAIL=you@your-domain.com

# === LLM Providers ===
# At least one provider must be configured. Research Harness routes by tier:
#   light tier  -> cheap/fast model  (summarize, classify)
#   medium tier -> balanced model    (claim_extract, gap_detect)
#   heavy tier  -> max quality model (consistency_check, adversarial review)

# OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Anthropic (Claude)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# === CLI Provider Flags ===
# Enable Codex CLI as a provider (heavy-tier tasks)
# CODEX_ENABLED=1

# Enable Cursor Agent CLI as a provider (light/medium tasks)
# CURSOR_AGENT_ENABLED=1

# === Tier Routing Overrides ===
# Format: provider:model
# LLM_ROUTE_LIGHT=openai:gpt-4o-mini
# LLM_ROUTE_MEDIUM=openai:gpt-4o
# LLM_ROUTE_HEAVY=anthropic:claude-opus-4-5

# === Proxy (optional) ===
# If using a local LLM proxy, set the port here.
# PROXY_PORT=8080

# === Execution Backend ===
# RESEARCH_HARNESS_BACKEND=claude_code   # default: local

# === fal.ai (optional — figure generation) ===
# FAL_KEY=YOUR_FAL_API_KEY_HERE

# === Additional Paper Sources (optional) ===
# Semantic Scholar (S2_API_KEY above is the canonical name; SEMANTIC_SCHOLAR_API_KEY is an alias)
# SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex (free; polite pool requires email)
# OPENALEX_MAILTO=you@your-domain.com
# OPENALEX_API_KEY=

# OpenReview (for ICLR / NeurIPS / ICML OpenReview mirrors)
# OPENREVIEW_ACCESS_TOKEN=
# OPENREVIEW_ENABLE=0

# PASA (paper agent search; disabled by default)
# PASA_ENABLE=0
# PASA_BASE_URL=

# Google Scholar via SerpAPI (paid)
# GOOGLE_SCHOLAR_API_KEY=
# GOOGLE_SCHOLAR_API_URL=

# Sci-Hub mirrors (opt-in; check your jurisdiction)
# SCIHUB_MIRRORS=

# === LLM Provider Overrides (optional) ===
# Model and base-URL overrides per provider — leave unset to use defaults.
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_MODEL=
# ANTHROPIC_AUTH_TOKEN=
# CODEX_MODEL=
# CURSOR_AGENT_MODEL=
# CHATGPT_API_KEY=
# CHATGPT_BASE_URL=
# CHATGPT_MODEL=
# PAPERINDEX_LLM_MODEL=

# === Filesystem (optional) ===
# Root directory for the repo when running utility scripts from elsewhere.
# Defaults to ~/code/research-harness.
# RESEARCH_HARNESS_ROOT=

# === Kimi (Moonshot) — optional ===
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# === JoyCode providers (INTERNAL — not available in open-source build) ===
# The joy_kimi / joy_gpt providers depend on a private library at ~/code/joycode
# and are disabled by default. Public users should rely on openai / anthropic /
# codex / cursor_agent instead. Leave these off unless you have a local
# JoyCode checkout.
# JOY_KIMI_ENABLED=0
# JOY_KIMI_MODEL=
# JOY_GPT_ENABLED=0
# JOY_GPT_MODEL=
# JOYCODE_PATH=~/code/joycode
